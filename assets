  <script>
  // ---- Game concept data lives in JS (logic, not user-editable content) ----
  const concepts = [
    { id:'sistema',    icon:'venus-and-mars', label:'Sistema Reprodutor', color:'#0f766e' },
    { id:'prevencao',  icon:'shield-check',   label:'Prevenção',          color:'#0891b2' },
    { id:'ist',        icon:'stethoscope',    label:'IST',                color:'#b45309' },
    { id:'exames',     icon:'clipboard-list', label:'Exames Preventivos', color:'#7c3aed' },
    { id:'consent',    icon:'handshake',      label:'Consentimento',      color:'#db2777' },
    { id:'respeito',   icon:'heart-handshake',label:'Respeito',           color:'#dc2626' },
    { id:'educacao',   icon:'book-open',      label:'Educação em Saúde',  color:'#2563eb' },
    { id:'autocuidado',icon:'sparkles',       label:'Autocuidado',        color:'#059669' },
    { id:'preservativo',icon:'shield',        label:'Proteção',           color:'#0d9488' },
    { id:'dialogo',    icon:'messages-square',label:'Diálogo Aberto',     color:'#ca8a04' }
  ];

  const board = document.getElementById('board');
  const feedback = document.getElementById('feedback-banner');
  const positiveMessages = ['Muito bem! 👏','Ótimo par! 🌟','Você está indo bem! 💚','Excelente aprendizado! ✨','Isso mesmo! 🎉'];

  let deck = [], first=null, second=null, lock=false, pairs=0, moves=0, score=0, muted=false;

  function shuffle(a){ for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a; }

  function buildDeck(){
    deck = shuffle([...concepts, ...concepts].map((c,i)=>({...c, uid:i})));
  }

  function renderBoard(){
    board.innerHTML='';
    const tpl = document.getElementById('card-template');
    deck.forEach(card=>{
      const node = tpl.content.cloneNode(true);
      const btn = node.querySelector('.memory-card');
      const icon = node.querySelector('.card-back .concept-icon');
      const label = node.querySelector('.card-label');
      icon.setAttribute('data-lucide', card.icon);
      icon.style.color = card.color;
      label.textContent = card.label;
      btn.dataset.id = card.id;
      btn.dataset.uid = card.uid;
      btn.addEventListener('click', ()=>flip(btn, card));
      board.appendChild(node);
    });
    lucide.createIcons();
  }

  function flip(btn, card){
    if(lock || btn.classList.contains('flipped') || btn.classList.contains('matched')) return;
    playClick();
    btn.classList.add('flipped');
    btn.setAttribute('aria-label', card.label);
    if(!first){ first={btn,card}; return; }
    second={btn,card};
    moves++; document.getElementById('moves-value').textContent=moves;
    lock=true;
    if(first.card.id===second.card.id){
      setTimeout(()=>{
        first.btn.classList.add('matched'); second.btn.classList.add('matched');
        first.btn.querySelector('.card-back').classList.add('pop');
        second.btn.querySelector('.card-back').classList.add('pop');
        pairs++; score+=100;
        document.getElementById('pairs-value').textContent=pairs;
        document.getElementById('score-value').textContent=score;
        playSuccess();
        showFeedback(positiveMessages[Math.floor(Math.random()*positiveMessages.length)]);
        reset();
        if(pairs===concepts.length) setTimeout(win, 700);
      }, 450);
    } else {
      playError();
      setTimeout(()=>{
        first.btn.classList.remove('flipped'); second.btn.classList.remove('flipped');
        first.btn.setAttribute('aria-label','Carta virada para baixo');
        second.btn.setAttribute('aria-label','Carta virada para baixo');
        reset();
      }, 900);
    }
  }
  function reset(){ first=null; second=null; lock=false; }

  function showFeedback(msg){
    feedback.textContent=msg; feedback.classList.remove('hidden');
    clearTimeout(showFeedback._t);
    showFeedback._t=setTimeout(()=>feedback.classList.add('hidden'), 1600);
  }

  function startGame(){
    pairs=0; moves=0; score=0;
    document.getElementById('pairs-value').textContent=0;
    document.getElementById('moves-value').textContent=0;
    document.getElementById('score-value').textContent=0;
    feedback.classList.add('hidden');
    buildDeck(); renderBoard(); reset();
    document.getElementById('start-screen').classList.add('hidden');
    document.getElementById('win-screen').classList.add('hidden');
    document.getElementById('game-screen').classList.remove('hidden');
  }

  function win(){
    document.getElementById('final-score').textContent=score;
    document.getElementById('game-screen').classList.add('hidden');
    document.getElementById('win-screen').classList.remove('hidden');
    playVictory();
  }

  // ---- Buttons ----
  document.getElementById('btn-start').addEventListener('click', ()=>{ initAudio(); startGame(); });
  document.getElementById('btn-restart').addEventListener('click', startGame);
  document.getElementById('btn-play-again').addEventListener('click', startGame);

  // Accessibility
  let scale=1;
  const applyScale=()=>document.documentElement.style.setProperty('--font-scale', scale);
  document.getElementById('btn-font-inc').addEventListener('click', ()=>{ scale=Math.min(1.5,scale+0.1); applyScale(); });
  document.getElementById('btn-font-dec').addEventListener('click', ()=>{ scale=Math.max(0.8,scale-0.1); applyScale(); });
  document.getElementById('btn-contrast').addEventListener('click', (e)=>{ const on=document.body.classList.toggle('contrast'); e.currentTarget.setAttribute('aria-pressed',on); });
  document.getElementById('btn-dark').addEventListener('click', (e)=>{ const on=document.body.classList.toggle('dark'); e.currentTarget.setAttribute('aria-pressed',on); });
  document.getElementById('btn-mute').addEventListener('click', (e)=>{ muted=!muted; e.currentTarget.setAttribute('aria-pressed',muted); });

  // ---- Web Audio (replaces mp3 files, which the sandbox blocks) ----
  let actx=null;
  function initAudio(){ if(!actx){ try{ actx=new (window.AudioContext||window.webkitAudioContext)(); }catch(e){} } if(actx&&actx.state==='suspended') actx.resume(); }
  function tone(freq,dur,type='sine',vol=0.15){
    if(muted||!actx) return;
    const o=actx.createOscillator(), g=actx.createGain();
    o.type=type; o.frequency.value=freq;
    o.connect(g); g.connect(actx.destination);
    const t=actx.currentTime;
    g.gain.setValueAtTime(0,t); g.gain.linearRampToValueAtTime(vol,t+0.02);
    g.gain.exponentialRampToValueAtTime(0.001,t+dur);
    o.start(t); o.stop(t+dur);
  }
  function playClick(){ initAudio(); tone(440,0.08,'triangle',0.12); }
  function playSuccess(){ initAudio(); tone(660,0.12,'sine'); setTimeout(()=>tone(880,0.16,'sine'),110); }
  function playError(){ initAudio(); tone(200,0.18,'sawtooth',0.1); }
  function playVictory(){ initAudio(); [523,659,784,1046].forEach((f,i)=>setTimeout(()=>tone(f,0.25,'sine'),i*150)); }

  lucide.createIcons();
</script>
